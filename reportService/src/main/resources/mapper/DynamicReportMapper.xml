<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.psbc.invres.resarchlibrary.mapper.doris.DynamicReportMapper">

    <!--
      通用动态查询：
      - 参数 sql 为完整的 SELECT 语句
      - 结果使用 MyBatis 默认的 Map 映射（列名 -> 值）
    -->
    <select id="executeSelect" parameterType="string" resultType="map">
        ${sql}
    </select>

</mapper>

